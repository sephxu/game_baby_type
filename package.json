{
  "name": "game-of-type",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "test": "node --test scripts/*.test.mjs src/**/*.test.mjs",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron": "npm run build:electron && electron dist-electron/main.js",
    "electron:check": "npm run build:electron && node --test src/electron/main.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.19.24",
    "electron": "^31.7.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.21"
  }
}
